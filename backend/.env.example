ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=["http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3002","http://127.0.0.1:3003","http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:3003"]

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=0
LLM_MODEL=
PERSONA_MODEL=
TRANSLATE_MODEL=
EVOLUTION_MODEL=
VISION_MODEL=
ASR_MODEL=
ENABLE_AI_CLASSIFICATION=false
ENABLE_VISION_OCR=false
ENABLE_ASR=false

# Local storage defaults to JSON files. Switch to sqlite only after running
# POST /api/v1/storage/sqlite/migrate and checking /api/v1/storage/verify.
LOCAL_STORAGE_BACKEND=json
LOCAL_SQLITE_PATH=data/local_store.sqlite3

# Authorized voice generation is disabled by default.
# Run IndexTTS2 as a separate local service before enabling these.
ENABLE_VOICE_GENERATION=false
VOICE_GENERATION_PROVIDER=indextts2
VOICE_GENERATION_BASE_URL=
VOICE_GENERATION_TIMEOUT_SECONDS=180
VOICE_REFERENCE_DIR=data/voice_references
VOICE_OUTPUT_DIR=data/voice_outputs
# Needed only when uploading video as a voice reference.
VOICE_VIDEO_FFMPEG_PATH=ffmpeg
VOICE_VIDEO_EXTRACT_TIMEOUT_SECONDS=120
